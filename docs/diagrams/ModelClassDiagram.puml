@startuml
!include style.puml
skinparam linetype ortho
skinparam sequenceMessageAlign right
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Package Model as ModelPackage <<Rectangle>> {
Class "<<interface>>\nReadOnlyAddressBook" as ReadOnlyAddressBook
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nModel" as Model
Class AddressBook
Class ModelManager
Class UserPrefs

Class UniquePersonList
Class UniqueServiceList
Class Person
Class Pet
Class Session
Class SessionEntry
Class Service
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

AddressBook .up.|> ReadOnlyAddressBook
ModelManager .up.|> Model
UserPrefs .up.|> ReadOnlyUserPrefs

Model .left.> ReadOnlyAddressBook
Model .right.> ReadOnlyUserPrefs
ModelManager -left-> "1" AddressBook
ModelManager -right-> "1" UserPrefs

AddressBook *--> "1" UniquePersonList
AddressBook *-down-> "1" UniqueServiceList
UniquePersonList -down-> "~*" Person
UniqueServiceList -down-> "~*" Service

Person *-down-> "*" Pet
Pet *-down-> "*" Session
Session -down-> "*" Service

ModelManager -down-> "~*"Person
ModelManager -down-> "~*"Service
ModelManager -down-> "~*"Pet
ModelManager -down-> "~*"SessionEntry
SessionEntry -up-> "1" Session

ReadOnlyAddressBook -[hidden]right-> Model
AddressBook -[hidden]right-> ModelManager
SessionEntry -[hidden]down-> Service


@enduml
