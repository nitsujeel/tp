<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.stage.Stage?>

<?import javafx.scene.control.Separator?>
<fx:root resizable="true" title="Help" type="javafx.stage.Stage"
         minWidth="500" minHeight="400"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <icons>
    <Image url="@/images/help_icon.png" />
  </icons>
  <scene>
    <Scene>
      <stylesheets>
        <URL value="@HelpWindow.css" />
      </stylesheets>

      <VBox id="helpWindowContainer">
        <ScrollPane id="commandScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS">
          <Label fx:id="commandsLabel" wrapText="true">
            <padding>
              <Insets top="15" right="15" bottom="15" left="15" />
            </padding>
          </Label>
        </ScrollPane>

        <Separator />

        <HBox id="helpMessageContainer" alignment="CENTER_LEFT" spacing="10">
          <padding>
            <Insets top="10" right="10" bottom="10" left="15" />
          </padding>
          <Label fx:id="helpMessage" text="Label" HBox.hgrow="ALWAYS" wrapText="true" />
          <Button fx:id="copyButton" mnemonicParsing="false" onAction="#copyUrl" text="Copy URL" />
        </HBox>
      </VBox>
    </Scene>
  </scene>
</fx:root>
